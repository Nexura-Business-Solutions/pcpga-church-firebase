rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admins are keyed by lowercased email (admins/{email}) so they can be
    // managed from the console without a uid lookup.
    function isStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    function isOwner() {
      return isStaff()
        && get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role == 'owner';
    }

    match /sermons/{id}   { allow read: if true;  allow write: if isStaff(); }
    match /library/{id}   { allow read: if true;  allow write: if isStaff(); }
    match /churches/{id}  { allow read: if true;  allow write: if isStaff(); }
    match /settings/{key} { allow read: if true;  allow write: if isStaff(); }
    match /donations/{id} { allow read: if isStaff(); allow write: if false; }
    match /donors/{id}    { allow read: if isStaff(); allow write: if false; }

    // A signed-in user may read their OWN admins doc (self-check, avoids the
    // old circular rule that hung the client on "Loading…"). Staff may list all
    // admins. Only an owner may grant/revoke admin or change roles.
    match /admins/{email} {
      allow read:  if request.auth != null && (request.auth.token.email == email || isStaff());
      allow write: if isOwner();
    }

    match /audit/{id}     { allow read: if isStaff(); allow create: if isStaff(); allow update, delete: if false; }
  }
}
