rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /sermons/{id}   { allow read: if true;  allow write: if isAdmin(); }
    match /library/{id}   { allow read: if true;  allow write: if isAdmin(); }
    match /churches/{id}  { allow read: if true;  allow write: if isAdmin(); }
    match /settings/{key} { allow read: if true;  allow write: if isAdmin(); }
    match /donations/{id} { allow read: if isAdmin(); allow write: if false; }
    match /donors/{id}    { allow read: if isAdmin(); allow write: if false; }
    match /admins/{uid}   { allow read: if isAdmin(); allow write: if false; }
    match /audit/{id}     { allow read: if isAdmin(); allow create: if isAdmin(); allow update, delete: if false; }
  }
}
