rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Admins are identified primarily by a custom auth claim (admin:true) set
    // on their user record — a self-contained check that needs no cross-service
    // call. The firestore.exists() lookup against admins/{email} is kept as a
    // fallback, BUT the Storage->Firestore cross-service call proved unreliable
    // on this project (it returned false for a valid admin and 403'd every
    // browser upload), so the claim is the real gate.
    // Granting the claim: set { admin: true } on the user (Admin SDK
    // setCustomUserClaims) — the user then re-logs in to refresh their token.
    // A new admin added via the Admins page must sign in once, then get the
    // claim. (TODO: a Firestore trigger on admins/{email} could automate this.)
    function isAdmin() {
      return request.auth != null
        && (request.auth.token.admin == true
            || firestore.exists(/databases/(default)/documents/admins/$(request.auth.token.email)));
    }

    match /sermons/{file=**}  { allow read: if true; allow write: if isAdmin(); }
    match /hero/{file=**}     { allow read: if true; allow write: if isAdmin(); }
    match /churches/{file=**} { allow read: if true; allow write: if isAdmin(); }
    match /library/{file=**}  { allow read: if true; allow write: if isAdmin(); }
    // Content editor: hero image, GCash/Maya QR, and announcement media.
    match /content/{file=**}  { allow read: if true; allow write: if isAdmin(); }
  }
}
